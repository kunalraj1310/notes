<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Draftly - Capture Your Ideas</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">

    <!-- Navbar -->
    <nav class="bg-white shadow-md">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
            <h1 class="text-3xl font-bold text-blue-600">Draftly</h1>

            <div class="space-x-4">
                <a href="/login" class="text-gray-700 hover:text-blue-600">Login</a>
                <a href="/register" class="bg-blue-600 text-white px-5 py-2 rounded-lg hover:bg-blue-700">
                    Get Started
                </a>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-6 py-24">
        <div class="grid md:grid-cols-2 gap-12 items-center">

            <div>
                <h2 class="text-5xl font-bold text-gray-900 leading-tight">
                    Your Ideas, Organized in One Place
                </h2>

                <p class="mt-6 text-lg text-gray-600">
                    Draftly helps you capture thoughts, create notes, and stay organized.
                    Whether you're a student, developer, or professional, your notes are always accessible.
                </p>

                <div class="mt-8 flex gap-4">
                    <a href="/register"
                       class="bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700">
                        Start Writing
                    </a>

                    <a href="#features"
                       class="border border-gray-300 px-6 py-3 rounded-lg hover:bg-gray-100">
                        Learn More
                    </a>
                </div>
            </div>

            <div>
                <img
                    src="https://images.unsplash.com/photo-1455390582262-044cdead277a"
                    alt="Notes App"
                    class="rounded-2xl shadow-xl">
            </div>

        </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="bg-white py-20">
        <div class="max-w-6xl mx-auto px-6">

            <h3 class="text-4xl font-bold text-center mb-12">
                Why Choose Draftly?
            </h3>

            <div class="grid md:grid-cols-3 gap-8">

                <div class="bg-gray-50 p-8 rounded-xl shadow">
                    <div class="text-4xl mb-4">📝</div>
                    <h4 class="text-xl font-semibold mb-2">
                        Quick Note Taking
                    </h4>
                    <p class="text-gray-600">
                        Capture ideas instantly and never miss an important thought.
                    </p>
                </div>

                <div class="bg-gray-50 p-8 rounded-xl shadow">
                    <div class="text-4xl mb-4">📂</div>
                    <h4 class="text-xl font-semibold mb-2">
                        Organize Notes
                    </h4>
                    <p class="text-gray-600">
                        Keep your notes structured and easy to find whenever you need them.
                    </p>
                </div>

                <div class="bg-gray-50 p-8 rounded-xl shadow">
                    <div class="text-4xl mb-4">🔒</div>
                    <h4 class="text-xl font-semibold mb-2">
                        Secure Access
                    </h4>
                    <p class="text-gray-600">
                        Your notes remain protected and accessible only to you.
                    </p>
                </div>

            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 bg-blue-600 text-white">
        <div class="max-w-4xl mx-auto text-center px-6">

            <h3 class="text-4xl font-bold mb-4">
                Start Writing Today
            </h3>

            <p class="text-lg mb-8">
                Join Draftly and keep all your ideas, notes, and plans organized.
            </p>

            <a href="/register"
               class="bg-white text-blue-600 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100">
                Create Free Account
            </a>

        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-400 py-6 text-center">
        <p>© 2026 Draftly. All rights reserved.</p>
    </footer>

</body>
</html>