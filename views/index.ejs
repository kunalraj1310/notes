<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Draftly - Notes Taking WebApp</title>

<link rel="icon" type="image/png" href="/images/notes-app-icon.png">
<link rel="stylesheet" href="/stylesheet/index.css">

<script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-gradient-to-br from-slate-100 via-blue-50 to-indigo-100 min-h-screen">

<div class="max-w-7xl mx-auto px-6 py-10">

    <!-- Header -->
    <div class="text-center mb-12">

        <h1 class="text-6xl font-black text-blue-900">
            Draftly
        </h1>

        <p class="text-gray-600 mt-3 text-lg">
            Capture ideas, save notes, stay organized.
        </p>

    </div>

    <!-- Create Note Form -->
    <div class="bg-white shadow-2xl rounded-3xl p-8 w-full max-w-xl mx-auto">

        <form action="/create" method="POST">

            <label class="block text-gray-700 font-semibold mb-2">
                Title
            </label>

            <input
                type="text"
                name="title"
                required
                placeholder="Enter note title"
                class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-4 focus:ring-blue-300 transition"
            >

            <label class="block text-gray-700 font-semibold mt-6 mb-2">
                Notes
            </label>

            <textarea
                name="note"
                required
                rows="5"
                placeholder="Write your notes here..."
                class="w-full border border-gray-300 rounded-xl px-4 py-3 resize-none focus:outline-none focus:ring-4 focus:ring-blue-300 transition"
            ></textarea>

            <button
                type="submit"
                class="w-full bg-blue-700 hover:bg-blue-800 text-white font-bold py-3 rounded-xl mt-8 transition"
            >
                Create Note
            </button>

        </form>

    </div>

    <!-- Notes Section -->
    <h2 class="text-4xl font-bold text-gray-800 text-center mt-16 mb-10">
        Your Notes
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">

        <% if(notes.length > 0){ %>

            <% notes.forEach(function(val){ %>

                <div class="bg-white rounded-3xl shadow-lg hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 p-6 flex flex-col justify-between">

                    <div>

                        <div class="text-5xl mb-4">
                            📝
                        </div>

                        <h3 class="text-xl font-bold text-gray-800 break-words">
                            <%= val.title %>
                        </h3>

                        <p class="text-gray-500 mt-3 text-sm leading-6">
                            <%= val.note.length > 10 ? val.note.substring(0,10) + '...' : val.note %>
                        </p>

                    </div>

                    <div class="flex gap-3 mt-6">

                        <a
                            href="/file/<%= val._id %>"
                            class="flex-1 text-center bg-blue-600 hover:bg-blue-700 text-white py-2 rounded-xl font-semibold transition"
                        >
                            Read
                        </a>

                        <a
                            href="/delete/<%= val._id %>"
                            onclick="return confirm('Are you sure you want to delete this note?')"
                            class="flex-1 text-center bg-red-500 hover:bg-red-600 text-white py-2 rounded-xl font-semibold transition"
                        >
                            Delete
                        </a>

                    </div>

                </div>

            <% }) %>

        <% } else { %>

            <div class="col-span-full text-center py-12">

                <div class="text-7xl mb-4">
                    📒
                </div>

                <h3 class="text-2xl font-bold text-gray-700">
                    No Notes Available
                </h3>

                <p class="text-gray-500 mt-2">
                    Create your first note to get started.
                </p>

            </div>

        <% } %>

    </div>

</div>

</body>
</html>
