<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Draftly - Notes Taking WebApp</title>

<link rel="icon" type="image/png" href="/images/notes-app-icon.png">
<link rel="stylesheet" href="/stylesheet/index.css">

    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-slate-100 min-h-screen">

<div class="max-w-7xl mx-auto px-6 py-10">

            <div class="h-16 flex justify-between items-center">

                <div class="flex items-center gap-3">

                    <div class="w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center text-white font-bold">
                        <a href="/">D</a>
                    </div>

                    <h1 class="text-2xl font-bold text-slate-800">
                         <a href="/">Draftly</a>
                    </h1>

                </div>

                <div class="flex items-center gap-4">

                    <div class="text-right">
                        <h3 class="font-semibold text-slate-800">
                            <%= user.username %>
                        </h3>

                        <p class="text-sm text-slate-500">
                            <%= user.notes.length %> Notes
                        </p>
                    </div>

                    <a
                        href="/logout"
                        class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-lg transition"
                    >
                        Logout
                    </a>

                </div>

            </div>

        </div>
    </nav>

    <!-- Main Content -->
    <div class="max-w-7xl mx-auto px-6 py-10">

        <!-- Welcome Section -->
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-5 mb-10">

            <div>

                <h1 class="text-4xl font-bold text-slate-800">
                    Welcome back, <%= user.username %>
                </h1>

                <p class="text-slate-500 mt-2">
                    Capture ideas, save notes, and stay organized.
                </p>

            </div>

            <button
                onclick="toggleForm()"
                class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl font-semibold transition"
            >
                + New Note
            </button>

        </div>

        <!-- Hidden Create Form -->
        <div
            id="noteForm"
            class="hidden bg-white rounded-2xl shadow-lg p-8 mb-12"
        >

            <div class="flex justify-between items-center mb-6">

                <h2 class="text-2xl font-bold text-slate-800">
                    Create New Note
                </h2>

                <button
                    onclick="toggleForm()"
                    class="text-slate-500 hover:text-red-500 text-xl"
                >
                    ✕
                </button>

            </div>

            <form action="/create" method="POST">

                <div class="mb-5">

                    <label class="block font-medium mb-2">
                        Title
                    </label>

                    <input
                        type="text"
                        name="title"
                        required
                        placeholder="Enter note title"
                        class="w-full border rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500"
                    >

                </div>

                <div class="mb-5">

                    <label class="block font-medium mb-2">
                        Note
                    </label>

                    <textarea
                        name="note"
                        rows="6"
                        required
                        placeholder="Write your note here..."
                        class="w-full border rounded-lg px-4 py-3 resize-none focus:outline-none focus:ring-2 focus:ring-blue-500"
                    ></textarea>

                </div>

                <button
                    type="submit"
                    class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-semibold transition"
                >
                    Create Note
                </button>

            </form>

        </div>

        <!-- Notes Header -->
        <div class="flex justify-between items-center mb-8">

            <h2 class="text-3xl font-bold text-slate-800">
                My Notes
            </h2>

            <span class="bg-white px-4 py-2 rounded-lg shadow text-slate-600">
                Total: <%= user.notes.length %>
            </span>

        </div>

        <!-- Notes Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">

            <% if(user.notes.length > 0){ %>

                <% user.notes.forEach(function(val){ %>

                    <div class="bg-white rounded-2xl border border-slate-200 p-5 hover:shadow-lg transition duration-300">

                        <div class="mb-4">

                            <div class="text-4xl mb-3">
                                📝
                            </div>

                            <h3 class="font-bold text-xl text-slate-800 break-words">
                                <%= val.title %>
                            </h3>

                            <p class="text-slate-500 mt-3 leading-6">
                                <%= val.note.length > 120
                                    ? val.note.substring(0,120) + '...'
                                    : val.note %>
                            </p>

                        </div>

                        <div class="flex gap-2 mt-5">

                            <a
                                href="/file/<%= val._id %>"
                                class="flex-1 text-center bg-slate-900 hover:bg-black text-white py-2 rounded-lg transition"
                            >
                                Open
                            </a>

                            <a
                                href="/delete/<%= val._id %>"
                                onclick="return confirm('Delete this note?')"
                                class="flex-1 text-center bg-red-500 hover:bg-red-600 text-white py-2 rounded-lg transition"
                            >
                                Delete
                            </a>

                        </div>

                    </div>

                <% }) %>

            <% } else { %>

                <div class="col-span-full">

                    <div class="bg-white rounded-2xl p-16 text-center shadow">

                        <div class="text-7xl mb-4">
                            📒
                        </div>

                        <h3 class="text-3xl font-bold text-slate-700">
                            No Notes Yet
                        </h3>

                        <p class="text-slate-500 mt-3">
                            Click "New Note" to create your first note.
                        </p>

                    </div>

                </div>

            <% } %>

        </div>

    </div>

</div>
            <script>
                    function toggleForm() {
                        const form = document.getElementById("noteForm");

                        form.classList.toggle("hidden");
                    }
            </script>

</body>
</html>
