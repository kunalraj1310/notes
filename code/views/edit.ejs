<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit - <%= edit.title %></title>

    <link rel="icon" type="image/png" href="/images/notes-app-icon.png">
    <link rel="stylesheet" href="/stylesheet/index.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-br from-blue-50 to-indigo-100 min-h-screen flex items-center justify-center p-6">

    <div class="bg-white shadow-xl rounded-3xl p-8 w-full max-w-2xl">

        <h1 class="text-3xl font-bold text-center text-blue-800 mb-8">
            Edit Note
        </h1>

        <form action="/update/<%= edit._id %>" method="POST">

            <!-- Title -->
            <label class="block text-gray-700 font-semibold mb-2">
                Title
            </label>

            <input
                type="text"
                name="editedtitle"
                value="<%= edit.title %>"
                required
                class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-4 focus:ring-blue-300"
            >

            <!-- Notes -->
            <label class="block text-gray-700 font-semibold mt-6 mb-2">
                Notes
            </label>

            <textarea
                name="editednote"
                rows="8"
                required
                class="w-full border border-gray-300 rounded-xl px-4 py-3 focus:outline-none focus:ring-4 focus:ring-blue-300 resize-none"
            ><%= edit.note %></textarea>

            <!-- Buttons -->
            <div class="flex gap-4 mt-8">

                <button
                    type="submit"
                    class="flex-1 bg-blue-700 hover:bg-blue-800 text-white font-bold py-3 rounded-xl transition"
                >
                    Update Note
                </button>

                <a href="/"
                   class="flex-1 text-center bg-gray-200 hover:bg-gray-300 text-gray-800 font-bold py-3 rounded-xl transition">
                    Cancel
                </a>

            </div>

        </form>

    </div>

</body>
</html>